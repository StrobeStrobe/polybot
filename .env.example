# Required for the LLM scouts and decision agent (NOT needed for `watch` mode)
ANTHROPIC_API_KEY=sk-ant-...

# Discord alerts for `watch` mode. Create one in your server:
# Server Settings -> Integrations -> Webhooks -> New Webhook -> Copy Webhook URL.
# Anyone with this URL can post to the channel — keep it out of git/cloud.
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/123456789/abcdef...

# --- Live trading only (leave unset for paper trading) ---
# Private key of the Polygon wallet that holds USDC for trading.
# NEVER fund this wallet with more than you can afford to lose.
# POLYGON_PRIVATE_KEY=0x...

# For Polymarket accounts created via email/Magic or browser wallet, set the
# proxy ("funder") address shown in your Polymarket profile and the matching
# signature type: 1 = email/Magic, 2 = browser wallet. EOA trading: leave unset.
# POLYMARKET_FUNDER=0x...
# POLYMARKET_SIGNATURE_TYPE=1

# Final safety latch: live mode refuses to start without this.
# POLYBOT_CONFIRM_LIVE=yes
